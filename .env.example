OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45
SIGNATURE_IMAGE_PATH=/Users/rafailvv/Documents/подпись.png
STAMP_IMAGE_PATH=/Users/rafailvv/Documents/Печать.png
OCR_LANGUAGES=rus+eng
WORKDIR=.runtime
APP_HOST=127.0.0.1
APP_PORT=8000
AUTH_REQUIRED=true
SECRET_KEY=change-this-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=10080
POSTGRES_DB=signing_documents
POSTGRES_USER=signing_documents
POSTGRES_PASSWORD=signing_documents
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
